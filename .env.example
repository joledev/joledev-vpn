# ============================================================
# joledev-vpn — Variables de entorno
# ============================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena TODOS los valores marcados con <CAMBIAR>
# 3. NUNCA commitees el archivo .env
# ============================================================

# ------ VPS / WireGuard ------

# IP pública o dominio del VPS (los peers se conectan aquí)
WG_HOST=69.62.68.130

# Puerto UDP de WireGuard (debe estar abierto en el firewall)
WG_PORT=51820

# Red interna VPN (no cambiar a menos que haya conflicto)
WG_DEFAULT_ADDRESS=10.8.0.x

# DNS que usarán los dispositivos conectados al VPN
WG_DEFAULT_DNS=1.1.1.1,1.0.0.1

# Todo el tráfico por VPN (full tunnel)
# Para split tunnel: ej. 10.8.0.0/24,192.168.0.0/16
WG_ALLOWED_IPS=0.0.0.0/0

# Keepalive para mantener conexión detrás de NAT (móviles especialmente)
WG_PERSISTENT_KEEPALIVE=25

# MTU — dejar vacío para auto, poner 1420 si hay problemas de conexión
WG_MTU=

# ------ Panel de administración (wg-easy) ------

# Contraseña del panel web
# Genera el hash con:
#   docker run --rm ghcr.io/wg-easy/wg-easy wgpw 'TU_PASSWORD'
# El hash resultante va aquí (los $ deben escaparse como $$)
PASSWORD_HASH=<CAMBIAR — bcrypt hash de tu contraseña>

# Puerto interno del panel (no exponer al exterior — Traefik lo maneja)
WG_UI_PORT=51821

# ------ K3s / Imágenes ------

# Namespace de K3s
K8S_NAMESPACE=joledev-vpn

# Imagen del manual web (tu GHCR)
DOCS_IMAGE=ghcr.io/joledev/joledev-vpn-docs:latest

# Nombre del ClusterIssuer de cert-manager
# Verificar con: kubectl get clusterissuer
CERT_ISSUER=letsencrypt-prod

# ------ Reglas NAT (generalmente no tocar) ------
WG_POST_UP=iptables -A FORWARD -i wg0 -j ACCEPT; iptables -t nat -A POSTROUTING -o eth0 -j MASQUERADE
WG_POST_DOWN=iptables -D FORWARD -i wg0 -j ACCEPT; iptables -t nat -D POSTROUTING -o eth0 -j MASQUERADE
